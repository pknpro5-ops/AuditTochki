# === AuditTochki Production Environment ===

# App
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://audittochki.ru

# Database (SQLite — path relative to project root)
DATABASE_URL="file:./prisma/prod.db"

# Auth
JWT_SECRET=generate-random-string-here-64-chars

# AI — Google Gemini (primary)
GEMINI_API_KEY=your-gemini-api-key

# AI — OpenRouter (fallback if Gemini quota exceeded)
OPENROUTER_API_KEY=your-openrouter-api-key

# Payments — YooKassa
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_RETURN_URL=https://audittochki.ru/audit/result

# Email — SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM=noreply@audittochki.ru

# Puppeteer for PDF generation
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
